---
import Header from "./Header.astro";
---

<Header />

<section id="landing-hero" class="relative isolate min-h-screen overflow-hidden bg-[#05091d] text-white">
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_18%,rgba(0,182,255,.2),transparent_42%),radial-gradient(circle_at_83%_67%,rgba(0,255,187,.14),transparent_36%),linear-gradient(135deg,#060b20_0%,#081131_45%,#0a143b_100%)]"></div>
    <div class="absolute -left-24 top-24 h-64 w-64 rounded-full bg-cyan-500/20 blur-3xl"></div>
    <div class="absolute -right-10 bottom-20 h-72 w-72 rounded-full bg-teal-400/15 blur-3xl"></div>
  </div>

  <div class="relative z-10 mx-auto grid min-h-screen max-w-7xl items-center gap-10 px-6 pb-14 pt-32 sm:px-10 lg:grid-cols-[1.05fr_0.95fr] lg:gap-14 lg:pt-40">
    <div class="max-w-2xl">
      <p
        data-hero-badge
        class="inline-flex items-center rounded-full border border-cyan-300/30 bg-cyan-400/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.12em] text-cyan-200"
      >
        Estrategia + Tecnología aplicada
      </p>

      <h1 class="mt-7 font-['Monda'] text-balance text-4xl font-bold leading-[1.08] sm:text-5xl lg:text-6xl">
        <span data-hero-title-line class="block">Convertimos los cuellos de botella</span>
        <span data-hero-title-line class="block">de tu negocio en</span>
        <span data-hero-title-line class="block text-cyan-300">ventajas digitales reales</span>
      </h1>

      <p data-hero-subtitle class="mt-6 max-w-xl text-pretty text-base leading-relaxed text-slate-200 sm:text-lg">
        Dejá de perder tiempo y dinero con sistemas que ya no te sirven. Desarrollamos soluciones tecnológicas a tu medida
        que escalan con tu negocio.
      </p>

      <div data-hero-actions class="mt-9 flex flex-wrap items-center gap-4">
        <a
          href="https://api.whatsapp.com/send?phone=50662020784"
          onclick="fbq('track', 'Contact');"
          class="inline-flex items-center justify-center rounded-xl bg-gradient-to-r from-[#00b4ff] to-[#0078ff] px-6 py-3 text-sm font-bold text-white shadow-[0_10px_30px_rgba(0,148,255,.35)] transition hover:-translate-y-0.5 hover:brightness-110"
        >
          Agendá tu Sesión Estratégica Gratis
        </a>
        <a
          href="#clientes"
          class="inline-flex items-center justify-center rounded-xl border border-white/25 bg-white/5 px-6 py-3 text-sm font-semibold text-white transition hover:-translate-y-0.5 hover:border-cyan-200/80 hover:bg-white/10"
        >
          Ver Nuestro Trabajo
        </a>
      </div>

      <p
        data-hero-trust
        class="mt-8 inline-flex flex-wrap items-center gap-x-2 gap-y-1 rounded-full border border-white/12 bg-white/5 px-5 py-3 text-xs font-semibold text-cyan-100 sm:text-sm"
      >
        ✦ 98% de satisfacción · ✦ +7 empresas transformadas · ✦ Respuesta en menos de 24h
      </p>
    </div>

    <div class="relative mx-auto w-full max-w-[540px]">
      <div
        data-hero-visual
        class="relative overflow-hidden rounded-3xl border border-cyan-200/20 bg-[radial-gradient(circle_at_50%_28%,rgba(32,200,223,.28),rgba(6,16,40,.92)_60%)] p-8 shadow-[0_25px_80px_rgba(2,10,40,.65)]"
      >
        <div class="hero-grid pointer-events-none absolute inset-0 opacity-30"></div>
        <div class="hero-orb-wrap pointer-events-none relative mx-auto mt-2 h-[300px] w-full max-w-[390px] sm:h-[340px]">
          <div id="hero-orb" class="hero-orb absolute left-1/2 top-1/2 h-[180px] w-[295px] -translate-x-1/2 -translate-y-1/2"></div>
          <div class="hero-shadow absolute bottom-8 left-1/2 h-10 w-[270px] -translate-x-1/2 rounded-[999px]"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-grid {
    background-image:
      linear-gradient(rgba(109, 252, 255, 0.18) 1px, transparent 1px),
      linear-gradient(90deg, rgba(109, 252, 255, 0.14) 1px, transparent 1px);
    background-size: 34px 34px;
    mask-image: radial-gradient(circle at center, black 42%, transparent 86%);
  }

  .hero-orb {
    border-radius: 999px;
    border: 1px solid rgba(130, 255, 252, 0.65);
    background:
      radial-gradient(circle at 30% 35%, rgba(180, 255, 255, 0.85), rgba(94, 211, 234, 0.28) 32%, rgba(13, 20, 52, 0.04) 66%),
      repeating-radial-gradient(
        circle at center,
        rgba(191, 253, 255, 0.28) 0 1px,
        rgba(9, 17, 43, 0.08) 1px 14px
      );
    box-shadow:
      inset 0 0 28px rgba(155, 250, 255, 0.38),
      0 0 50px rgba(27, 210, 224, 0.22),
      0 18px 55px rgba(1, 10, 33, 0.7);
    transform: translate(-50%, -50%) rotate(-16deg);
  }

  .hero-shadow {
    background: radial-gradient(circle at center, rgba(110, 255, 242, 0.32), rgba(3, 7, 22, 0));
    filter: blur(8px);
  }
</style>

<script>
  import { gsap } from "gsap";

  const hero = document.getElementById("landing-hero");
  const visual = document.querySelector("[data-hero-visual]");
  const orb = document.getElementById("hero-orb");
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (hero && !reduceMotion) {
    gsap.set("[data-hero-title-line]", { willChange: "transform, opacity" });
    gsap.set("[data-hero-subtitle],[data-hero-actions],[data-hero-trust],[data-hero-visual]", { willChange: "transform, opacity" });

    const intro = gsap.timeline({
      defaults: { duration: 0.82, ease: "power3.out" },
      onComplete: () => gsap.set("[data-hero-title-line],[data-hero-subtitle],[data-hero-actions],[data-hero-trust],[data-hero-visual]", { clearProps: "willChange" }),
    });

    intro
      .from("[data-hero-badge]", { y: 16, opacity: 0, duration: 0.45 })
      .from("[data-hero-title-line]", { y: 24, opacity: 0, stagger: 0.1 }, "-=0.1")
      .from("[data-hero-subtitle]", { y: 16, opacity: 0 }, "-=0.45")
      .from("[data-hero-actions]", { y: 14, opacity: 0 }, "-=0.52")
      .from("[data-hero-trust]", { y: 10, opacity: 0 }, "-=0.52")
      .from("[data-hero-visual]", { x: 28, opacity: 0, scale: 0.97, duration: 1 }, "-=0.75");

    if (orb) {
      gsap.to(orb, {
        y: -10,
        duration: 3.2,
        repeat: -1,
        yoyo: true,
        ease: "sine.inOut",
      });
    }

    if (visual) {
      const toX = gsap.quickTo(visual, "x", { duration: 0.65, ease: "power3.out" });
      const toY = gsap.quickTo(visual, "y", { duration: 0.65, ease: "power3.out" });
      const toR = gsap.quickTo(visual, "rotation", { duration: 0.8, ease: "power3.out" });
      let bounds = visual.getBoundingClientRect();

      const refreshBounds = () => {
        bounds = visual.getBoundingClientRect();
      };

      const onMove = (event) => {
        const offsetX = event.clientX - (bounds.left + bounds.width / 2);
        const offsetY = event.clientY - (bounds.top + bounds.height / 2);
        const x = gsap.utils.clamp(-10, 10, (offsetX / bounds.width) * 26);
        const y = gsap.utils.clamp(-10, 10, (offsetY / bounds.height) * 22);

        toX(x);
        toY(y);
        toR(x * 0.35);
      };

      hero.addEventListener("pointerenter", refreshBounds, { passive: true });
      hero.addEventListener("pointermove", onMove, { passive: true });
      hero.addEventListener("pointerleave", () => {
        toX(0);
        toY(0);
        toR(0);
      });
      window.addEventListener("resize", refreshBounds, { passive: true });
    }
  }
</script>
